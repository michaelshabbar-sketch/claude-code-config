      "Read(**/.pypirc)",
      "Read(**/.pgpass)",
      "Read(**/.htpasswd)",
      "Read(**/*.ovpn)",
      "Read(~/.config/git/credentials)",
      "Read(**/.dockercfg)",
      "Read(**/credentials.json)",
      "Read(**/.credentials)",
      "Read(**/credentials.yml)",
      "Read(**/credentials.yaml)",
      "Read(**/secrets.json)",
      "Read(**/secrets.yaml)",
      "Read(**/secrets.yml)",
      "Read(**/.secrets)",
      "Read(**/*.secret)",
      "Read(**/client_secret*.json)"
