# secrets.sh.example — copy to secrets.sh and fill in. secrets.sh is gitignored.
# setup.sh sources ./secrets.sh automatically if it exists.
# NEVER commit real values.

export GITHUB_PERSONAL_ACCESS_TOKEN="<your_github_pat>"
export GMAIL_CLIENT_ID="<your_gmail_oauth_client_id>"
export GMAIL_CLIENT_SECRET="<your_gmail_oauth_client_secret>"

# Optional: narrow the filesystem MCP root (defaults to $HOME)
# export FS_ROOT="$HOME/projects"
